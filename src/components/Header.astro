---
export interface Props {
  /** Current page for active nav styling: 'home' | 'about' */
  currentPage?: string;
}
const { currentPage } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<header class="fixed top-0 left-0 right-0 bg-white/80 backdrop-blur-md border-b border-gray-200 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Name (left) -->
      <a href={base} class="text-xl font-bold text-gray-900 hover:text-primary transition-colors flex items-center">
        Tina Yan
      </a>

      <!-- Navigation (right) - fixed height and structure so position is identical on all pages -->
      <nav class="hidden md:flex items-center gap-8" id="main-nav">
        <a href={`${base}about`} data-nav="about" class={`inline-flex items-center h-8 font-medium border-b-2 box-border transition-colors nav-link ${currentPage === 'about' ? 'text-gray-900 border-gray-900 font-bold' : 'text-gray-700 border-transparent hover:text-primary'}`}>
          About
        </a>
        <a href={`${base}#projects`} data-nav="projects" class={`inline-flex items-center h-8 font-medium border-b-2 border-transparent box-border transition-colors nav-link ${currentPage === 'about' ? 'text-gray-700 hover:text-primary' : 'text-gray-700 hover:text-primary'}`}>
          Projects
        </a>
        <a href={`${base}#contact`} data-nav="contact" class={`inline-flex items-center h-8 font-medium border-b-2 border-transparent box-border transition-colors nav-link ${currentPage === 'about' ? 'text-gray-700 hover:text-primary' : 'text-gray-700 hover:text-primary'}`}>
          Contacts
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button class="md:hidden p-2 rounded-md text-gray-700 hover:text-primary hover:bg-gray-100 transition-colors" id="mobile-menu-button">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
    
    <!-- Mobile menu -->
    <div class="md:hidden hidden" id="mobile-menu">
      <div class="px-2 pt-2 pb-3 space-y-1 bg-white border-t border-gray-200">
        <a href={`${base}about`} class={`block px-3 py-2 font-medium transition-colors ${currentPage === 'about' ? 'text-gray-900' : 'text-gray-700 hover:text-primary'}`}>
          About
        </a>
        <a href={`${base}#projects`} class="block px-3 py-2 text-gray-700 hover:text-primary transition-colors font-medium">
          Projects
        </a>
        <a href={`${base}#contact`} class="block px-3 py-2 text-gray-700 hover:text-primary transition-colors font-medium">
          Contacts
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  
  mobileMenuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
  
  const mobileLinks = mobileMenu?.querySelectorAll('a');
  mobileLinks?.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });

  // On home page: highlight Projects/Contacts when section is in view or after click
  const projectsSection = document.getElementById('projects');
  const contactSection = document.getElementById('contact');
  if (projectsSection && contactSection) {
    const navProjects = document.querySelector('[data-nav="projects"]');
    const navContact = document.querySelector('[data-nav="contact"]');
    const setActive = (section = '') => {
      navProjects?.classList.remove('font-bold', 'text-gray-900', 'border-gray-900');
      navProjects?.classList.add('text-gray-700');
      navContact?.classList.remove('font-bold', 'text-gray-900', 'border-gray-900');
      navContact?.classList.add('text-gray-700');
      if (section === 'projects') {
        navProjects?.classList.add('font-bold', 'text-gray-900', 'border-gray-900');
        navProjects?.classList.remove('text-gray-700');
      } else if (section === 'contact') {
        navContact?.classList.add('font-bold', 'text-gray-900', 'border-gray-900');
        navContact?.classList.remove('text-gray-700');
      }
    };
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const id = entry.target.id;
          if (id === 'projects') setActive('projects');
          if (id === 'contact') setActive('contact');
        });
      },
      { rootMargin: '-20% 0px -60% 0px', threshold: 0 }
    );
    observer.observe(projectsSection);
    observer.observe(contactSection);
    // Update on scroll to handle which section is "most" in view
    const updateActiveOnScroll = () => {
      const projRect = projectsSection.getBoundingClientRect();
      const contactRect = contactSection.getBoundingClientRect();
      const vh = window.innerHeight;
      const projCenter = projRect.top + projRect.height / 2;
      const contactCenter = contactRect.top + contactRect.height / 2;
      if (contactCenter < vh * 0.6) setActive('contact');
      else if (projCenter < vh * 0.6) setActive('projects');
      else setActive('');
    };
    window.addEventListener('scroll', updateActiveOnScroll, { passive: true });
    updateActiveOnScroll();
  }
</script>
