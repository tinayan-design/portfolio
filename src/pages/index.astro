---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => {
  if (a.data.order && b.data.order) {
    return a.data.order - b.data.order;
  }
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<Layout title="Tina Yan - UI/UX Designer" description="UI/UX Designer creating innovative digital experiences. View my portfolio of mobile apps, websites, and design systems.">
  <Header />

  <main id="main-content">
  <!-- Hero: full-width blurred background (hero-bg.png), centered text block with overlay -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden px-4 sm:px-6 lg:px-8 pt-24 pb-16">
    <!-- Background image: soft blur + reduced brightness -->
    <div class="absolute inset-0 z-0" aria-hidden="true">
      <img
        src={`${import.meta.env.BASE_URL}images/hero-bg.png`}
        alt=""
        class="absolute inset-0 w-full h-full object-cover object-center blur-md brightness-95"
      />
    </div>
    <!-- Hero text: centered, aligned with project cards (max-w-5xl), 80% overlay for visibility -->
    <div class="relative z-10 max-w-5xl mx-auto w-full px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto bg-[#f5f5f5]/90 backdrop-blur-sm rounded-2xl p-8 md:p-10 text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary-text mb-4">UI/UX Designer</p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight">
          Hi, I'm <span class="text-primary-text whitespace-nowrap">Tina Yan</span>
        </h1>
        <p class="max-w-lg mx-auto text-gray-900 text-xl font-medium leading-relaxed mb-10">
          I design user-centered digital experiences—clear, useful, and thoughtful.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a
            href="#projects"
            class="inline-flex items-center justify-center px-6 py-3 bg-primary hover:bg-primary/90 text-white font-medium rounded-lg transition-colors"
          >
            Projects
          </a>
          <a
            href="https://www.linkedin.com/in/tina-yan-2a3952170/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 py-3 bg-white border-2 border-gray-800 text-gray-800 font-medium rounded-lg hover:bg-gray-800 hover:text-white transition-colors"
            aria-label="LinkedIn (opens in new window)"
          >
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects: centered title with underline, alternating cards -->
  <section id="projects" class="pt-20 md:pt-24 pb-28 md:pb-36 bg-white px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-2">Projects</h2>
      <div class="w-16 h-1 bg-primary mx-auto mb-14" role="presentation"></div>

      <div class="flex flex-col gap-16 md:gap-20">
        {sortedProjects.map((project, i) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            image={project.data.image}
            tags={project.data.tags}
            projectUrl={project.data.projectUrl}
            slug={project.slug}
            templateStyle={true}
            imageOnLeft={i % 2 === 1}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-12 md:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Let's Work Together</h2>
      <p class="text-gray-600 mb-8">
        I'm always interested in new opportunities and collaborations.
      </p>
      <a
        href="mailto:yanlamji@gmail.com"
        class="inline-flex items-center px-6 py-3 border-2 border-gray-800 text-gray-800 font-medium rounded-lg hover:bg-gray-800 hover:text-white transition-colors"
      >
        Get in touch
      </a>
    </div>
  </section>

  <!-- Footer: social icons + copyright -->
  <footer class="pt-8 pb-10 bg-white border-t border-gray-200">
    <div class="max-w-5xl mx-auto px-4 flex flex-col items-center gap-6">
      <div class="flex items-center justify-center gap-8">
        <a href="https://www.linkedin.com/in/tina-yan-2a3952170/" target="_blank" rel="noopener noreferrer" class="text-gray-700 hover:text-primary-text transition-colors" aria-label="LinkedIn (opens in new window)">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="mailto:yanlamji@gmail.com" class="text-gray-700 hover:text-primary-text transition-colors" aria-label="Email Tina">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </a>
      </div>
      <p class="text-gray-500 text-sm">Tina Yan 2026</p>
    </div>
  </footer>
  </main>
</Layout>
