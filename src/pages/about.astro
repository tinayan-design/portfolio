          <!-- Artwork 5: Photo frame -->
          <div>
            <img
              src={`${import.meta.env.BASE_URL}images/craft/photo-frame.png`}
              alt="Hand-painted photo frame with whimsical sky and daisy motif across outer and inner layers"
              width="4032"
              height="3024"
              class="max-w-full h-auto block"
              loading="lazy"
            />
            <p class="mt-6 text-gray-700 leading-relaxed max-w-2xl mx-auto text-center md:text-left">
              Exploring continuity by extending a whimsical sky and daisy motif across the layers of a photo frame. This piece demonstrates my eye for thematic consistency and my passion for transforming functional objects into engaging, delightful visual experiences that tell a story.
            </p>
          </div>

          <!-- Section: Studies & Interpretations -->
          <h3 class="text-xl font-bold text-gray-900 mt-16 mb-8 pt-8 border-t border-gray-200">Studies & Interpretations</h3>
          <!-- Studies & Interpretations 1: Starry Night tribute -->
          <div>
            <img
              src={`${import.meta.env.BASE_URL}images/craft/starry-night.png`}
              alt="Tribute to Van Gogh's The Starry Night with swirling sky and expressive brushwork"
              width="4032"
              height="3024"
              class="max-w-full h-auto block"
              loading="lazy"
            />
            <p class="mt-6 text-gray-700 leading-relaxed max-w-2xl mx-auto text-center md:text-left">
              A tribute to Van Gogh's The Starry Night, exploring movement and rhythm through expressive brushwork. This piece demonstrates my eye for visual energy and flow, highlighting how swirling forms and high-contrast accents can guide a viewer's attention across a composition.
            </p>
          </div>
          <!-- Studies & Interpretations 2: Monet-inspired water lilies -->
          <div>
            <img
              src={`${import.meta.env.BASE_URL}images/craft/water-lilies.png`}
              alt="Monet-inspired impressionist study of water lilies, willow branches, and serene light"
              width="4032"
              height="3024"
              class="max-w-full h-auto block"
              loading="lazy"
            />
            <p class="mt-6 text-gray-700 leading-relaxed max-w-2xl mx-auto text-center md:text-left">
              An impressionist study of tranquility and light. Inspired by Monet, this painting explores organic forms and a serene palette, showcasing my eye for atmospheric harmony and my dedication to learning from classical masters to inform my modern design work.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    // @ts-nocheck - inline script; DOM types in browser
    const tabButtons = document.querySelectorAll('[data-tab-button]');
    const tabList = document.querySelector('[role="tablist"]');

    function activateTab(btn) {
      if (!btn) return;
      const tab = btn.getAttribute('data-tab-button');
      tabButtons.forEach(b => {
        const selected = b === btn;
        b.setAttribute('aria-selected', selected ? 'true' : 'false');
        b.classList.toggle('bg-white', selected);
        b.classList.toggle('border-primary', selected);
        b.classList.toggle('shadow-sm', selected);
        b.classList.toggle('text-gray-900', selected);
        b.classList.toggle('border-transparent', !selected);
        b.classList.toggle('text-gray-600', !selected);
      });
      document.querySelectorAll('[data-tab-panel]').forEach(panel => {
        const show = panel.getAttribute('data-tab-panel') === tab;
        panel.classList.toggle('hidden', !show);
        panel.setAttribute('aria-hidden', show ? 'false' : 'true');
      });
    }

    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => activateTab(btn));
    });

    tabList?.addEventListener('keydown', (e) => {
      const ev = /** @type {KeyboardEvent} */ (e);
      const tabs = Array.from(tabButtons);
      const currentIndex = tabs.indexOf(document.activeElement);
      if (currentIndex === -1) return;
      let nextIndex = currentIndex;
      if (ev.key === 'ArrowRight' || ev.key === 'ArrowDown') {
        ev.preventDefault();
        nextIndex = (currentIndex + 1) % tabs.length;
      } else if (ev.key === 'ArrowLeft' || ev.key === 'ArrowUp') {
        ev.preventDefault();
        nextIndex = (currentIndex - 1 + tabs.length) % tabs.length;
      } else if (ev.key === 'Home') {
        ev.preventDefault();
        nextIndex = 0;
      } else if (ev.key === 'End') {
        ev.preventDefault();
        nextIndex = tabs.length - 1;
      }
      if (nextIndex !== currentIndex) {
        const next = tabs[nextIndex];
        if (next) {
          if (typeof next.focus === 'function') next.focus();
          activateTab(next);
        }
      }
    });
  </script>

  <!-- Contact -->
